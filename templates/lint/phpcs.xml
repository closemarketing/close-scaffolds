<?xml version="1.0"?>
<ruleset name="{{PLUGIN_NAME}} Coding Standards">
    <description>WordPress Coding Standards for {{PLUGIN_NAME}}</description>

    <!-- What to scan -->
    <file>.</file>
    
    <!-- Exclude patterns -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/includes/theme/patterns/*</exclude-pattern>
    <exclude-pattern>*/includes/blocks/*/build/*</exclude-pattern>
    <exclude-pattern>*/includes/blocks/node_modules/*</exclude-pattern>
    <exclude-pattern>*.min.js</exclude-pattern>
    <exclude-pattern>*.asset.php</exclude-pattern>

    <!-- How to scan -->
    <arg value="sp"/> <!-- Show sniff and progress -->
    <arg name="basepath" value="."/>
    <arg name="colors"/>
    <arg name="extensions" value="php"/>
    <arg name="parallel" value="8"/>

    <!-- Rules: Check PHP version compatibility -->
    <config name="testVersion" value="7.4-"/>

    <!-- Rules: WordPress Coding Standards -->
    <rule ref="WordPress">
        <!-- Allow short array syntax -->
        <exclude name="Generic.Arrays.DisallowShortArraySyntax"/>
        
        <!-- Allow short ternary -->
        <exclude name="WordPress.PHP.DisallowShortTernary"/>
    </rule>

    <!-- Rules: WordPress Extra Standards -->
    <rule ref="WordPress-Extra">
        <!-- Exclude filename rules -->
        <exclude name="WordPress.Files.FileName"/>
        
        <!-- Allow multiple statements on same line -->
        <exclude name="Squiz.PHP.DisallowMultipleAssignments"/>
    </rule>

    <!-- Rules: WordPress Docs Standards -->
    <rule ref="WordPress-Docs"/>

    <!-- Use Yoda conditions -->
    <rule ref="WordPress.PHP.YodaConditions"/>

    <!-- Verify that everything is properly escaped for security -->
    <rule ref="WordPress.Security.EscapeOutput"/>
    <rule ref="WordPress.Security.NonceVerification"/>
    <rule ref="WordPress.Security.ValidatedSanitizedInput"/>

    <!-- Check for PHP cross-version compatibility -->
    <rule ref="PHPCompatibilityWP"/>

    <!-- Minimum PHP version -->
    <config name="minimum_supported_wp_version" value="6.0"/>

    <!-- Text domain check -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="{{TEXT_DOMAIN}}"/>
            </property>
        </properties>
    </rule>

    <!-- Naming conventions -->
    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" type="array">
                <element value="{{PREFIX}}"/>
                <element value="{{PREFIX_UPPER}}"/>
            </property>
        </properties>
    </rule>

    <!-- Allow for theme specific exceptions -->
    <rule ref="WordPress.Files.FileName">
        <properties>
            <property name="strict_class_file_names" value="false"/>
        </properties>
        <exclude-pattern>*/includes/theme/*</exclude-pattern>
    </rule>

    <!-- Hook priority must be integer -->
    <rule ref="WordPress.WP.AlternativeFunctions"/>
    
    <!-- Use wp_safe_redirect instead of wp_redirect -->
    <rule ref="WordPress.Security.SafeRedirect"/>
</ruleset>

