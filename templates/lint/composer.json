{
  "name": "closemarketing/{{PLUGIN_SLUG}}-lint",
  "description": "PHPStan configuration for {{PLUGIN_NAME}}",
  "type": "library",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "{{PLUGIN_AUTHOR}}",
      "homepage": "https://close.marketing"
    }
  ],
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "phpstan/phpstan": "^1.11",
    "phpstan/extension-installer": "^1.4",
    "php-stubs/wordpress-stubs": "^6.4",
    "php-stubs/wp-cli-stubs": "^3.0",
    "szepeviktor/phpstan-wordpress": "^1.3"
  },
  "autoload": {
    "classmap": [
      "includes"
    ]
  },
  "scripts": {
    "phpstan": "phpstan analyse -c phpstan.neon.dist --memory-limit=512M"
  },
  "config": {
    "allow-plugins": {
      "phpstan/extension-installer": true
    }
  }
}
