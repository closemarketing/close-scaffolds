{
  "name": "{{PLUGIN_SLUG}}/lint-config",
  "description": "PHPStan and WordPress Coding Standards configuration for {{PLUGIN_NAME}}",
  "type": "project",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "{{PLUGIN_AUTHOR}}",
      "email": "info@close.marketing"
    }
  ],
  "require-dev": {
    "phpstan/phpstan": "^1.10",
    "szepeviktor/phpstan-wordpress": "^1.3",
    "phpstan/extension-installer": "^1.3",
    "squizlabs/php_codesniffer": "^3.7",
    "wp-coding-standards/wpcs": "^3.0",
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "phpstan/extension-installer": true
    },
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "scripts": {
    "phpstan": "phpstan analyse --memory-limit=2G",
    "phpcs": "phpcs --standard=phpcs.xml",
    "phpcbf": "phpcbf --standard=phpcs.xml",
    "lint": [
      "@phpcs",
      "@phpstan"
    ],
    "lint:fix": "@phpcbf"
  },
  "scripts-descriptions": {
    "phpstan": "Run PHPStan static analysis",
    "phpcs": "Run PHP_CodeSniffer to detect coding standard violations",
    "phpcbf": "Run PHP Code Beautifier to automatically fix coding standard violations",
    "lint": "Run all linting tools (PHPCS + PHPStan)",
    "lint:fix": "Automatically fix coding standard violations"
  }
}

